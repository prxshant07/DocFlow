# ===========================================
# Railway Deployment Environment Variables
# ===========================================
# Add these to your Railway project's Variables tab

# --- Database (Railway PostgreSQL) ---
# Use Railway's internal DATABASE_URL for asyncpg
DATABASE_URL=postgresql+asyncpg://docflow:docflow@localhost:5432/docflow
DATABASE_URL_SYNC=postgresql://docflow:docflow@localhost:5432/docflow

# --- Redis (Railway Redis) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Storage ---
UPLOAD_DIR=/tmp/docflow/uploads
MAX_FILE_SIZE_MB=50

# --- App ---
DEBUG=false
CORS_ORIGINS=["*"]
